# ==========================================================
# Terraform
# ==========================================================

**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfstate.lock.info
crash.log

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore Terraform plan files
*.tfplan
plan.out

# Ignore Terraform CLI configuration
terraform.rc
.terraformrc

# Ignore generated ZIP packages
*.zip

# Ignore Terraform variable files (may contain secrets)
*.tfvars
!*.tfvars.example

# Ignore local Terraform lock file
**/.terraform.lock.hcl

# ==========================================================
# AWS
# ==========================================================

.aws/
*.pem

# ==========================================================
# Node.js
# ==========================================================

**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore only the root package-lock.json
/package-lock.json

# ==========================================================
# Test Files
# ==========================================================

test.txt
*.log

# ==========================================================
# IDE
# ==========================================================

.vscode/
.idea/

# ==========================================================
# Operating System
# ==========================================================

.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# Python
# ==========================================================

__pycache__/
*.pyc

# ==========================================================
# Miscellaneous
# ==========================================================

.env
.env.*